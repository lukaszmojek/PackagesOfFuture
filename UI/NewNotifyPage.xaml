<Page x:Class="UI.NewNotifyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UI"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="NewNotifyPage">

    <Grid Background="#FFFF88E9">
        <Button x:Name="BackButton" Content="Wróć do menu" HorizontalAlignment="Left" Margin="45,709,0,0" VerticalAlignment="Top" Height="39" Width="157" Foreground="White" FontWeight="Bold" FontSize="20" Background="#FF3AFF00" Click="BackButton_Click" />
        <Label Content="Każde zgłoszenie rozpatrywane  jest indywidualnie,&#xD;&#xA; prosze opisz swój problem" HorizontalAlignment="Left" Margin="124,71,0,0" VerticalAlignment="Top" Height="152" Width="576" FontWeight="Bold" FontSize="20"/>
        <Button x:Name="NewNotifyButton" Content="Zatwierdź zgłoszenie" HorizontalAlignment="Left" Margin="502,709,0,0" VerticalAlignment="Top" Height="39" Width="220" Foreground="White" FontWeight="Bold" FontSize="20" Background="#FF3AFF00" />
        <TextBox x:Name="NotifyDescription" HorizontalAlignment="Left" Margin="195,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Width="324" Height="325"/>
    </Grid>
</Page>
