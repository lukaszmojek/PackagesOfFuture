<Page x:Class="UI.StartupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UI"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="StartupPage">

    <Grid Width="800" Height="800">
        <Grid.Background>
            <ImageBrush ImageSource="/startupPageBackground.jpg"/>
        </Grid.Background>
        <Label Content="Strona startowa" HorizontalAlignment="Left" Margin="22,21,0,0" VerticalAlignment="Top" Height="69" Width="716" Foreground="White" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <Button x:Name="LoginButton" Content="Zaloguj sie" HorizontalAlignment="Left" Margin="429,498,0,0" VerticalAlignment="Top" Height="60" Width="103" Click="LoginButton_Click"/>
        <Button x:Name="RegisterButton" Content="Zarejestruj się" HorizontalAlignment="Left" Margin="429,400,0,0" VerticalAlignment="Top" Height="60" Width="103" Click="RegisterButton_Click"/>

    </Grid>
</Page>
