<Page x:Class="UI.AdminIssuesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UI"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="AdminIssuesPage">

    <Grid Background="#FFFFB5B5">
        <Grid Margin="101,134,195,193" Background="#FF766E6E">
            <ListView x:Name="IssuesListView">
                <ListView.View>
                    <GridView>
                        <GridView.Columns>
                            <GridViewColumn Header="Id" DisplayMemberBinding="{Binding Path=Id}"/>
                            <GridViewColumn Header="Opis" DisplayMemberBinding="{Binding Path=Description}"/>
                            <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Path=Status}"/>
                        </GridView.Columns>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        <Button x:Name="BackButton" Content="Powrot" HorizontalAlignment="Left" Margin="36,728,0,0" VerticalAlignment="Top" Height="26" Width="98" Click="BackButton_Click"/>

    </Grid>
</Page>
