<Page x:Class="UI.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UI"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="AdminPage">

    <Grid Background="#FFFF5A5A">
        <Button x:Name="LogoutButton" Content="Wyloguj" HorizontalAlignment="Left" Margin="39,696,0,0" VerticalAlignment="Top" Height="44" Width="70" Click="LogoutButton_Click"/>
        <Label Content="Panel administratora" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Foreground="White" FontWeight="Bold" FontSize="20" Height="34" RenderTransformOrigin="0.567,0.162"/>
        <Button x:Name="AddUserButton" Content="Dodaj &#xD;&#xA;użytkownika" HorizontalAlignment="Left" Margin="74,80,0,0" VerticalAlignment="Top" Height="53" Width="83" Click="AddUserButton_Click"/>
        <Button x:Name="DeleteUsersButton" Content="Usun uzytkownika" HorizontalAlignment="Left" Margin="420,80,0,0" VerticalAlignment="Top" Height="53" Width="83" Click="DeleteUsersButton_Click"/>
        <Button x:Name="IssuesButton" Content="Zgloszenia" HorizontalAlignment="Left" Margin="297,304,0,0" VerticalAlignment="Top" Height="66" Width="103" Click="IssuesButton_Click"/>

    </Grid>
</Page>
